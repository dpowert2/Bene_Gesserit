# Bene Gesserit — environment variables
#
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local
#
# In production, set these in your Vercel project (Settings → Environment Variables).

# ────────────────────────────────────────────────────────────────────
# Database (Turso / libSQL)
# ────────────────────────────────────────────────────────────────────
# Create a free DB at https://turso.tech, then:
#   turso db show <name> --url       → DATABASE_URL
#   turso db tokens create <name>    → DATABASE_AUTH_TOKEN
#
# Or use a local libSQL file for development:
#   DATABASE_URL=file:./local.db
#   (DATABASE_AUTH_TOKEN can be omitted for local file mode)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ────────────────────────────────────────────────────────────────────
# Anthropic API
# ────────────────────────────────────────────────────────────────────
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — override default model. Defaults to a current Claude model.
# ANTHROPIC_MODEL=

# ────────────────────────────────────────────────────────────────────
# Auth
# ────────────────────────────────────────────────────────────────────
# Single-user password gate. Pick a strong value.
# Rotating this invalidates all outstanding session cookies.
BG_PASSWORD=

# Optional — name shown next to your votes/notes. Defaults to "you".
BG_VOTER_NAME=

# ────────────────────────────────────────────────────────────────────
# Cron auth (optional)
# ────────────────────────────────────────────────────────────────────
# Vercel Cron sends a CRON_SECRET header on scheduled invocations.
# If set, cron API routes require this header. Vercel sets this automatically
# when you configure cron in vercel.json, but you can override here.
# CRON_SECRET=
